{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/codex/pre_tool_use.py",
            "timeout": 30,
            "statusMessage": "Checking Markdown publish gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$|Edit|Write$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/codex/post_tool_use.py",
            "timeout": 60,
            "statusMessage": "Checking Markdown final-state hygiene"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/codex/stop.py",
            "timeout": 10,
            "statusMessage": "Checking Markdown delivery"
          }
        ]
      }
    ]
  }
}
