{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/dist/cli.js\" hook pre-tool-use",
            "timeout": 30,
            "statusMessage": "Checking Markdown publish gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$|^apply_patch$|^Edit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/dist/cli.js\" hook post-tool-use",
            "timeout": 60,
            "statusMessage": "Checking Markdown final-state hygiene"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/dist/cli.js\" hook stop",
            "timeout": 15,
            "statusMessage": "Checking Markdown delivery"
          }
        ]
      }
    ]
  }
}
