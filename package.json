{
  "name": "markdown-gate",
  "version": "0.1.0",
  "description": "Promptfoo-backed Markdown final-state hygiene gate for AI-authored docs",
  "type": "module",
  "license": "MIT",
  "author": "zlh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ztcshen/markdown-gate.git"
  },
  "bugs": {
    "url": "https://github.com/ztcshen/markdown-gate/issues"
  },
  "homepage": "https://github.com/ztcshen/markdown-gate#readme",
  "keywords": [
    "markdown",
    "promptfoo",
    "codex",
    "hooks",
    "llm-evals",
    "documentation"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "markdown-gate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "evals",
    "rules",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "audit:high": "npm audit --audit-level=high",
    "check": "npm run typecheck && npm run lint && npm test",
    "eval": "promptfoo eval -c evals/promptfooconfig.yaml",
    "eval:llm": "promptfoo eval -c evals/promptfooconfig.llm.yaml",
    "format": "biome format --write .",
    "lint": "biome check .",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "rules:check": "tsx src/cli.ts rules check",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "promptfoo": "^0.121.17",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
