{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "files": {
    "includes": ["**", "!dist", "!node_modules", "!coverage", "!*.tgz"]
  }
}
